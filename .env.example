# LXC File Hub environment configuration
# Copy to .env and adjust for your environment.

# Hub
LXCFH_VERSION=dev
LXCFH_COMMIT=local
LXCFH_BUILD_DATE=
LXCFH_IMAGE=lxcfh/hub:latest
LXCFH_HOST_PORT=8080
LXCFH_BIND_HOST=0.0.0.0
LXCFH_BIND_PORT=8080
LXCFH_DB_PATH=/var/lib/lxcfh/lxcfh.db

# SMB / FUSE — set SMB_ENABLED=true to mount FUSE and export via Samba sidecar
SMB_ENABLED=false
LXCFH_SAMBA_IMAGE=lxcfh/samba:latest
SMB_USER=lxcfh
SMB_PASSWORD=changeme
SMB_SHARE_NAME=lxcfh
SMB_HOST_PORT=445
SMB_NBT_PORT=139

# Test SFTP node (profile: test)
TEST_NODE_PUID=1000
TEST_NODE_PGID=1000
TEST_NODE_USER=sftpuser
TEST_NODE_PASSWORD=sftppass
TEST_NODE_SSH_PORT=2222

TZ=UTC
